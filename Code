  const newPass = document.getElementById('reset-pass').value;
  const errorEl = document.getElementById('reset-error');
  const successEl = document.getElementById('reset-success');
  const btn = document.getElementById('reset-submit');

  if (!newPass || newPass.length < 6) {
    errorEl.textContent = "Password must be at least 6 characters.";
    errorEl.style.display = 'block';
    return;
  }

  btn.disabled = true;
  btn.style.opacity = '0.7';
  btn.textContent = 'Updating...';
  errorEl.style.display = 'none';

  try {
    await confirmPasswordReset(auth, resetCode, newPass);
    successEl.textContent = "Password updated successfully!";
    successEl.style.display = 'block';
    setTimeout(() => go('s-auth'), 2000);
  } catch (err) {
    errorEl.textContent = err.message.replace('Firebase: ', '');
    errorEl.style.display = 'block';
    btn.disabled = false;
    btn.style.opacity = '1';
    btn.textContent = 'Update Password →';
  }
}

// Handle Email Action Code
const urlParams = new URLSearchParams(window.location.search);
const mode = urlParams.get('mode');
const oobCode = urlParams.get('oobCode');

if (mode === 'resetPassword' && oobCode) {
  resetCode = oobCode;
  // Verify code first
  verifyPasswordResetCode(auth, oobCode).then(() => {
    go('s-reset');
  }).catch(err => {
    alert("Invalid or expired reset link.");
    go('s-auth');
  });
}

window.handleLogout = async function() {
  try {
    await signOut(auth);
  } catch (err) {
    console.error("Logout failed", err);
  }
}

// Auth State Monitor
onAuthStateChanged(auth, (user) => {
  currentUser = user;
  const loading = document.getElementById('loading');
  
  if (user) {
    // User is signed in
    if (document.getElementById('s-auth').classList.contains('active')) {
      go('s-home');
    }
  } else {
    // User is signed out
    go('s-auth');
  }
  
  // Fade out loading
  loading.style.opacity = '0';
  setTimeout(() => loading.style.display = 'none', 300);
});
</script>
</body>
</html>
