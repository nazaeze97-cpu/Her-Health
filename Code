<script>
const hideTab = ['s-welcome','s-win'];
const tabMap = {'s-home':0,'s-book':1,'s-tracker':2,'s-directory':3,'s-wellness':4};

function go(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.getElementById('tabbar').style.display = hideTab.includes(id) ? 'none' : 'flex';
  if (tabMap[id] !== undefined) {
    document.querySelectorAll('.tab').forEach((t,i) => t.classList.toggle('on', i === tabMap[id]));
  }
  document.querySelector('.frame').scrollTop = 0;
}

function switchTab(el, id) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('on'));
  el.classList.add('on');
  go(id);
}

function pickPkg(card) {
  document.querySelectorAll('.pkg-card').forEach(c => c.classList.remove('chosen'));
  card.classList.add('chosen');
  setTimeout(() => {
    document.getElementById('bk-1').style.display = 'none';
    document.getElementById('bk-2').style.display = 'block';
    document.getElementById('prog').style.width = '66%';
  }, 280);
}

function nextBk() {
  document.getElementById('bk-2').style.display = 'none';
  document.getElementById('bk-3').style.display = 'block';
  document.getElementById('prog').style.width = '100%';
}

function rate(dot) {
  const dots = dot.parentElement.children;
  const idx = Array.from(dots).indexOf(dot);
  Array.from(dots).forEach((d,i) => d.classList.toggle('lit', i <= idx));
}

function saveLog() {
  const btn = document.getElementById('save-btn');
  btn.textContent = '✅ Saved!';
  btn.style.background = 'var(--moss)';
  setTimeout(() => {
    btn.textContent = "Save Today's Log ✓";
    btn.style.background = 'var(--clay)';
  }, 2000);
}

function togglePostForm() {
  const f = document.getElementById('post-form');
  f.style.display = f.style.display === 'block' ? 'none' : 'block';
  if (f.style.display === 'block') f.scrollIntoView({ behavior: 'smooth' });
}

function postWin() { go('s-win'); }

// chips toggle
document.querySelectorAll('.chip').forEach(c => {
  c.addEventListener('click', () => c.classList.toggle('on'));
});

// filter pills
document.querySelectorAll('.filter-pill').forEach(p => {
  p.addEventListener('click', function() {
    this.closest('.filter-row').querySelectorAll('.filter-pill').forEach(x => x.classList.remove('on'));
    this.classList.add('on');
  });
});

// hide tab on load
document.getElementById('tabbar').style.display = 'none';

// Safety timeout: If Firebase takes too long, hide loading and show auth
setTimeout(() => {
  const loading = document.getElementById('loading');
  if (loading && loading.style.display !== 'none') {
    loading.style.opacity = '0';
    setTimeout(() => loading.style.display = 'none', 300);
    if (!document.querySelector('.screen.active')) {
      if (typeof go === 'function') go('s-auth');
    }
  }
}, 5000);
</script>

