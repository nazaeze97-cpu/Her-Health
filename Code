<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HerHealth</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,200;0,9..144,300;0,9..144,400;1,9..144,200;1,9..144,300;1,9..144,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<script type="importmap">
  {
    "imports": {
      "firebase/app": "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js",
      "firebase/auth": "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js",
      "firebase/analytics": "https://www.gstatic.com/firebasejs/10.8.0/firebase-analytics.js"
    }
  }
</script>
<style>
:root {
  --ink: #0E0800;
  --clay: #B85C38;
  --clay-deep: #8C3D20;
  --clay-light: #E8A882;
  --parchment: #FBF6EE;
  --linen: #F5EDE0;
  --moss: #4A6741;
  --moss-light: #E8EFE6;
  --gold: #BF9B4A;
  --gold-pale: #F0E6C8;
  --dust: #9C8572;
  --white: #FEFCF9;
  --card-shadow: 0 4px 24px rgba(14,8,0,0.08);
  --card-shadow-hover: 0 12px 40px rgba(14,8,0,0.14);
}

* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

body {
  font-family: 'Jost', sans-serif;
  background: #E8DDD0;
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.frame {
  width: 100%;
  max-width: 390px;
  min-height: 100vh;
  background: var(--parchment);
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 80px rgba(0,0,0,0.25);
}

/* SCREENS */
.screen { display: none; flex-direction: column; min-height: 100vh; }
.screen.active { display: flex; animation: rise 0.4s cubic-bezier(0.16,1,0.3,1); }

@keyframes rise {
  from { opacity:0; transform:translateY(16px); }
  to { opacity:1; transform:translateY(0); }
}

.scrollable { flex:1; overflow-y:auto; padding-bottom:100px; }
.scrollable::-webkit-scrollbar { display:none; }

/* ── WELCOME ───────────────────────────────── */
.welcome {
  min-height: 100vh;
  background: var(--ink);
  display: flex;
  flex-direction: column;
  padding: 0;
  position: relative;
  overflow: hidden;
}

.welcome-texture {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 110% 10%, rgba(184,92,56,0.35) 0%, transparent 60%),
    radial-gradient(ellipse 60% 80% at -10% 90%, rgba(191,155,74,0.2) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 50% 50%, rgba(184,92,56,0.08) 0%, transparent 70%);
  pointer-events: none;
}

.welcome-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.welcome-orb-1 {
  width: 280px; height: 280px;
  top: -80px; right: -80px;
  background: radial-gradient(circle, rgba(184,92,56,0.25) 0%, transparent 70%);
  animation: breathe 6s ease-in-out infinite;
}

.welcome-orb-2 {
  width: 200px; height: 200px;
  bottom: 100px; left: -60px;
  background: radial-gradient(circle, rgba(191,155,74,0.18) 0%, transparent 70%);
  animation: breathe 8s ease-in-out infinite reverse;
}

@keyframes breathe {
  0%,100% { transform: scale(1); opacity:1; }
  50% { transform: scale(1.15); opacity:0.7; }
}

.welcome-content {
  position: relative; z-index: 2;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  flex: 1;
  padding: 60px 32px 40px;
  text-align: center;
}

.welcome-emblem {
  width: 72px; height: 72px;
  border-radius: 50%;
  border: 1px solid rgba(191,155,74,0.4);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 28px;
  position: relative;
  animation: rise 0.6s cubic-bezier(0.16,1,0.3,1) 0.1s both;
}

.welcome-emblem::before {
  content: '';
  position: absolute; inset: 4px;
  border-radius: 50%;
  border: 1px solid rgba(191,155,74,0.2);
}

.welcome-emblem-inner {
  font-size: 28px;
  filter: drop-shadow(0 0 12px rgba(191,155,74,0.4));
}

.welcome-wordmark {
  font-family: 'Fraunces', serif;
  font-size: 44px;
  font-weight: 200;
  letter-spacing: -1px;
  color: #fff;
  line-height: 1;
  margin-bottom: 6px;
  animation: rise 0.6s cubic-bezier(0.16,1,0.3,1) 0.15s both;
}

.welcome-wordmark em {
  font-style: italic;
  color: var(--clay-light);
}

.welcome-sub {
  font-size: 10px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  margin-bottom: 48px;
  animation: rise 0.6s cubic-bezier(0.16,1,0.3,1) 0.2s both;
}

.welcome-stat-row {
  display: flex;
  gap: 1px;
  width: 100%;
  background: rgba(255,255,255,0.06);
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.06);
  margin-bottom: 40px;
  animation: rise 0.6s cubic-bezier(0.16,1,0.3,1) 0.25s both;
}

.w-stat {
  flex: 1;
  padding: 16px 10px;
  text-align: center;
  background: rgba(255,255,255,0.03);
}

.w-stat + .w-stat { border-left: 1px solid rgba(255,255,255,0.06); }
.w-stat-n { font-family:'Fraunces',serif; font-size:22px; font-weight:300; color:var(--gold); display:block; }
.w-stat-l { font-size:10px; color:rgba(255,255,255,0.35); margin-top:3px; display:block; line-height:1.3; }

.welcome-headline {
  font-family: 'Fraunces', serif;
  font-size: 30px;
  font-weight: 200;
  color: #fff;
  line-height: 1.35;
  margin-bottom: 14px;
  animation: rise 0.6s cubic-bezier(0.16,1,0.3,1) 0.3s both;
}

.welcome-headline em { font-style:italic; color:var(--clay-light); }

.welcome-body {
  font-size: 13px;
  color: rgba(255,255,255,0.45);
  line-height: 1.9;
  margin-bottom: 44px;
  animation: rise 0.6s cubic-bezier(0.16,1,0.3,1) 0.35s both;
}

.welcome-ctas {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 10px;
  animation: rise 0.6s cubic-bezier(0.16,1,0.3,1) 0.4s both;
}

.btn-clay {
  background: var(--clay);
  color: #fff;
  border: none;
  border-radius: 14px;
  padding: 17px 28px;
  font-family: 'Jost', sans-serif;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.3px;
  width: 100%;
  cursor: pointer;
  transition: all 0.25s;
  position: relative;
  overflow: hidden;
}

.btn-clay::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, transparent 60%);
}

.btn-clay:hover { background: var(--clay-deep); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(184,92,56,0.4); }

.btn-ghost {
  background: transparent;
  color: rgba(255,255,255,0.5);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 14px;
  padding: 15px 28px;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  width: 100%;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-ghost:hover { border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.7); }

/* ── BOTTOM TAB ─────────────────────────────── */
.tab-bar {
  position: fixed;
  bottom: 0; left: 50%;
  transform: translateX(-50%);
  width: 390px;
  background: rgba(251,246,238,0.95);
  backdrop-filter: blur(20px);
  border-top: 1px solid rgba(184,92,56,0.08);
  display: flex;
  z-index: 500;
  padding: 6px 0 12px;
}

.tab {
  flex: 1;
  display: flex; flex-direction: column;
  align-items: center; gap: 3px;
  padding: 8px 0 2px;
  cursor: pointer;
  transition: all 0.2s;
}

.tab-ico { font-size: 20px; transition: all 0.2s; }
.tab-lbl { font-size: 9px; font-weight: 500; letter-spacing: 0.5px; color: #B8A898; text-transform: uppercase; transition: all 0.2s; }
.tab.on .tab-ico { transform: translateY(-2px); }
.tab.on .tab-lbl { color: var(--clay); font-weight: 600; }

/* ── TOP NAV ────────────────────────────────── */
.topnav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 20px 14px;
  position: sticky; top: 0; z-index: 100;
  background: rgba(251,246,238,0.9);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(184,92,56,0.06);
}

.topnav-logo {
  font-family: 'Fraunces', serif;
  font-size: 20px; font-weight: 300;
  color: var(--ink); letter-spacing: -0.5px;
}

.topnav-logo em { font-style:italic; color:var(--clay); }

.topnav-back {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: var(--linen);
  border: none;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; cursor: pointer;
  transition: all 0.2s;
}

.topnav-back:hover { background: var(--gold-pale); }

/* ── HOME ───────────────────────────────────── */
.home-hero {
  background: var(--ink);
  padding: 28px 22px 32px;
  position: relative;
  overflow: hidden;
}

.home-hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 100% 0%, rgba(184,92,56,0.3) 0%, transparent 60%),
    radial-gradient(ellipse 50% 80% at 0% 100%, rgba(191,155,74,0.15) 0%, transparent 60%);
  pointer-events: none;
}

.home-greeting {
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  margin-bottom: 12px;
  position: relative; z-index: 1;
}

.home-headline {
  font-family: 'Fraunces', serif;
  font-size: 32px;
  font-weight: 200;
  color: #fff;
  line-height: 1.25;
  margin-bottom: 24px;
  position: relative; z-index: 1;
}

.home-headline em { font-style:italic; color:var(--clay-light); }

.home-pills {
  display: flex; gap: 8px;
  position: relative; z-index: 1;
  flex-wrap: wrap;
}

.home-pill {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  padding: 7px 14px;
  font-size: 12px;
  color: rgba(255,255,255,0.6);
  display: flex; align-items: center; gap: 6px;
}

.home-pill span { font-size: 14px; }

/* QUICK GRID */
.qgrid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  padding: 22px 18px;
}

.qcard {
  border-radius: 20px;
  padding: 18px 16px;
  cursor: pointer;
  transition: all 0.25s;
  position: relative;
  overflow: hidden;
  min-height: 110px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.qcard:hover { transform: translateY(-3px); box-shadow: var(--card-shadow-hover); }

.qcard-a {
  background: var(--clay);
  box-shadow: 0 4px 20px rgba(184,92,56,0.3);
}

.qcard-a::after {
  content: '';
  position: absolute; top: -20px; right: -20px;
  width: 80px; height: 80px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
}

.qcard-b { background: var(--white); border: 1px solid rgba(184,92,56,0.08); box-shadow: var(--card-shadow); }
.qcard-c { background: var(--white); border: 1px solid rgba(184,92,56,0.08); box-shadow: var(--card-shadow); }

.qcard-d {
  background: var(--moss);
  box-shadow: 0 4px 20px rgba(74,103,65,0.3);
}

.qcard-d::after {
  content: '';
  position: absolute; bottom: -20px; left: -20px;
  width: 80px; height: 80px;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}

.qcard-ico { font-size: 24px; margin-bottom: 10px; }
.qcard-title { font-size: 13px; font-weight: 600; line-height: 1.3; }
.qcard-desc { font-size: 11px; margin-top: 3px; line-height: 1.4; }

.qcard-a .qcard-title, .qcard-a .qcard-desc { color: #fff; }
.qcard-a .qcard-desc { color: rgba(255,255,255,0.7); }
.qcard-d .qcard-title, .qcard-d .qcard-desc { color: #fff; }
.qcard-d .qcard-desc { color: rgba(255,255,255,0.7); }
.qcard-b .qcard-title, .qcard-c .qcard-title { color: var(--ink); }
.qcard-b .qcard-desc, .qcard-c .qcard-desc { color: var(--dust); }

/* STORY */
.story-wrap { padding: 4px 18px 20px; }

.story-card {
  background: var(--ink);
  border-radius: 24px;
  padding: 26px 22px;
  position: relative;
  overflow: hidden;
}

.story-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 100% 0%, rgba(184,92,56,0.3) 0%, transparent 60%);
  pointer-events: none;
}

.story-quote-mark {
  font-family: 'Fraunces', serif;
  font-size: 120px;
  line-height: 0.7;
  color: rgba(184,92,56,0.2);
  position: absolute;
  top: 20px; right: 16px;
  pointer-events: none;
  font-style: italic;
}

.story-text {
  font-family: 'Fraunces', serif;
  font-size: 16px;
  font-weight: 200;
  font-style: italic;
  color: rgba(255,255,255,0.88);
  line-height: 1.75;
  margin-bottom: 20px;
  position: relative; z-index: 1;
}

.story-author {
  display: flex; align-items: center; gap: 12px;
  position: relative; z-index: 1;
}

.story-av {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--clay), var(--clay-deep));
  display: flex; align-items: center; justify-content: center;
  font-size: 15px; font-weight: 600; color: #fff;
  border: 1.5px solid rgba(255,255,255,0.15);
}

.story-name { font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.8); }
.story-detail { font-size: 11px; color: rgba(255,255,255,0.35); margin-top: 1px; }

/* SECTION HEADER */
.sec-head {
  display: flex; justify-content: space-between; align-items: baseline;
  padding: 20px 18px 12px;
}

.sec-title {
  font-family: 'Fraunces', serif;
  font-size: 20px; font-weight: 300;
  color: var(--ink); letter-spacing: -0.3px;
}

.sec-title em { font-style:italic; color:var(--clay); }

/* RESOURCE SCROLL */
.rscroll {
  display: flex; gap: 10px;
  overflow-x: auto;
  padding: 0 18px 4px;
  scrollbar-width: none;
}
.rscroll::-webkit-scrollbar { display:none; }

.rcard {
  background: var(--white);
  border-radius: 18px;
  padding: 16px;
  min-width: 150px;
  flex-shrink: 0;
  border: 1px solid rgba(184,92,56,0.07);
  box-shadow: var(--card-shadow);
  cursor: pointer;
  transition: all 0.2s;
}

.rcard:hover { transform: translateY(-2px); box-shadow: var(--card-shadow-hover); }
.rcard-ico { font-size: 26px; margin-bottom: 10px; display: block; }
.rcard-title { font-size: 12px; font-weight: 600; color: var(--ink); line-height: 1.4; }
.rcard-type { font-size: 10px; color: var(--dust); margin-top: 6px; text-transform: uppercase; letter-spacing: 0.8px; }

/* ── BOOK ───────────────────────────────────── */
.book-wrap { padding: 20px 18px 90px; }

.disclaimer {
  background: linear-gradient(135deg, rgba(184,92,56,0.06), rgba(184,92,56,0.03));
  border: 1px solid rgba(184,92,56,0.12);
  border-radius: 14px;
  padding: 14px 16px;
  margin-bottom: 22px;
  font-size: 12px;
  color: var(--dust);
  line-height: 1.65;
}

.disclaimer strong { color: var(--clay); }

.progress-track {
  height: 2px;
  background: rgba(184,92,56,0.1);
  border-radius: 2px;
  margin-bottom: 26px;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--clay), var(--gold));
  border-radius: 2px;
  transition: width 0.5s cubic-bezier(0.16,1,0.3,1);
}

.step-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--dust);
  margin-bottom: 6px;
}

.step-title {
  font-family: 'Fraunces', serif;
  font-size: 22px;
  font-weight: 300;
  color: var(--ink);
  margin-bottom: 6px;
}

.step-title em { font-style:italic; color:var(--clay); }
.step-desc { font-size: 13px; color: var(--dust); line-height: 1.6; margin-bottom: 24px; }

/* PACKAGE CARDS */
.pkg-card {
  background: var(--white);
  border-radius: 20px;
  padding: 20px;
  margin-bottom: 12px;
  border: 1.5px solid rgba(184,92,56,0.08);
  box-shadow: var(--card-shadow);
  cursor: pointer;
  transition: all 0.25s;
  display: flex; gap: 16px; align-items: flex-start;
}

.pkg-card:hover { transform: translateY(-2px); box-shadow: var(--card-shadow-hover); border-color: rgba(184,92,56,0.2); }

.pkg-card.chosen {
  border-color: var(--clay);
  background: linear-gradient(135deg, rgba(184,92,56,0.04), var(--white));
  box-shadow: 0 4px 24px rgba(184,92,56,0.15);
}

.pkg-ico {
  width: 50px; height: 50px;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; flex-shrink: 0;
}

.pkg-name { font-size: 15px; font-weight: 600; color: var(--ink); margin-bottom: 5px; }
.pkg-desc { font-size: 12px; color: var(--dust); line-height: 1.55; }
.pkg-price { font-size: 14px; font-weight: 600; color: var(--clay); margin-top: 10px; display: flex; align-items: center; gap: 8px; }
.pkg-save { font-size: 11px; font-weight: 500; color: var(--moss); background: var(--moss-light); padding: 2px 8px; border-radius: 6px; }

/* FORM */
.fgroup { margin-bottom: 18px; }

.flabel {
  font-size: 10px; font-weight: 600;
  letter-spacing: 1.2px; text-transform: uppercase;
  color: var(--dust); margin-bottom: 8px; display: block;
}

.finput {
  width: 100%;
  background: var(--white);
  border: 1.5px solid rgba(184,92,56,0.12);
  border-radius: 13px;
  padding: 13px 16px;
  font-family: 'Jost', sans-serif;
  font-size: 14px; color: var(--ink);
  outline: none; transition: all 0.2s;
}

.finput:focus {
  border-color: var(--clay);
  box-shadow: 0 0 0 3px rgba(184,92,56,0.08);
}

.fselect {
  width: 100%;
  background: var(--white);
  border: 1.5px solid rgba(184,92,56,0.12);
  border-radius: 13px;
  padding: 13px 16px;
  font-family: 'Jost', sans-serif;
  font-size: 14px; color: var(--ink);
  outline: none; appearance: none; cursor: pointer;
}

.ftextarea {
  width: 100%;
  background: var(--white);
  border: 1.5px solid rgba(184,92,56,0.12);
  border-radius: 13px;
  padding: 13px 16px;
  font-family: 'Jost', sans-serif;
  font-size: 14px; color: var(--ink);
  outline: none; resize: none; min-height: 100px;
  transition: all 0.2s; line-height: 1.6;
}

.ftextarea:focus { border-color: var(--clay); }

/* CHIPS */
.chips { display:flex; flex-wrap:wrap; gap:8px; }

.chip {
  background: var(--white);
  border: 1.5px solid rgba(184,92,56,0.12);
  border-radius: 20px;
  padding: 8px 14px;
  font-size: 12px; font-weight: 500;
  color: var(--ink); cursor: pointer;
  transition: all 0.2s;
}

.chip:hover, .chip.on {
  background: var(--clay);
  border-color: var(--clay);
  color: #fff;
}

.chip.moss:hover, .chip.moss.on {
  background: var(--moss);
  border-color: var(--moss);
  color: #fff;
}

/* BUTTONS */
.btn-primary {
  background: var(--clay);
  color: #fff; border: none;
  border-radius: 14px;
  padding: 16px 24px;
  font-family: 'Jost', sans-serif;
  font-size: 14px; font-weight: 500;
  width: 100%; cursor: pointer;
  transition: all 0.25s;
  letter-spacing: 0.3px;
  position: relative; overflow: hidden;
}

.btn-primary::after {
  content:'';
  position:absolute; inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,0.12) 0%,transparent 60%);
}

.btn-primary:hover { background: var(--clay-deep); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(184,92,56,0.35); }

.btn-outline {
  background: transparent;
  color: var(--clay);
  border: 1.5px solid var(--clay);
  border-radius: 14px;
  padding: 14px 24px;
  font-family: 'Jost', sans-serif;
  font-size: 14px; font-weight: 500;
  width: 100%; cursor: pointer;
  transition: all 0.2s;
  margin-top: 10px;
}

.btn-moss {
  background: var(--moss);
  color: #fff; border: none;
  border-radius: 14px;
